{
  "$schema": "https://raw.githubusercontent.com/nicedoc/openapi-schemata/main/tauri/tauri-v2-config.schema.json",
  "productName": "Sistemas Gestor",
  "version": "1.0.0",
  "identifier": "com.alkosto.sistemas-gestor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../.next/standalone",
    "devUrl": "http://localhost:3001"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Sistemas Gestor - Administracion de Equipos",
        "width": 1200,
        "height": 800,
        "maximized": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "es-CO"
      }
    }
  }
}
